{
  "name": "atom-mission-lab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Atom mission planner: program waypoint flight forms and export PotensicPro-compatible map.db",
  "license": "MIT",
  "homepage": "https://patbaumgartner.github.io/potensic-atom-mission-lab/",
  "repository": {
    "type": "git",
    "url": "https://github.com/patbaumgartner/potensic-atom-mission-lab.git"
  },
  "bugs": {
    "url": "https://github.com/patbaumgartner/potensic-atom-mission-lab/issues"
  },
  "keywords": [
    "potensic",
    "atom",
    "drone",
    "waypoint",
    "mission-planner",
    "map-db",
    "potensicpro"
  ],
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsgo -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsgo -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit:prod": "npm audit --omit=dev",
    "generate:sample": "tsx scripts/generate-sample-mapdb.ts",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.22",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "knip": "^6.26.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.9"
  }
}
